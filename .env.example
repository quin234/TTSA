# Copy this file to .env and fill in the real values before deploying.
# This project uses python-decouple; all settings are read from the environment.

# Core Django
DEBUG=False
SECRET_KEY=change-me-to-a-randomly-generated-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,smartcampus.co.ke,www.smartcampus.co.ke

# Database (MySQL in production; configure a dedicated user and strong password)
DB_ENGINE=django.db.backends.mysql
DB_NAME=ttsa_academy
DB_USER=ttsa_app
DB_PASSWORD=change-me-to-a-strong-password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CONN_MAX_AGE=600

# Redis / Cache / Channels / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security (enable only when HTTPS is correctly terminated)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
USE_X_FORWARDED_PROTO=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_TRUSTED_ORIGINS=https://smartcampus.co.ke,https://www.smartcampus.co.ke

# YouTube Data API v3 key
YOUTUBE_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_LEVEL_CONSOLE=INFO
LOG_LEVEL_FILE=INFO
LOG_LEVEL_DJANGO=INFO
LOG_LEVEL_APP=INFO
